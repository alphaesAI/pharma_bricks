      "ControlFile": "WITH Header AS(\r\nSELECT \r\n   ReportingPeriodStartDate\r\n  ,ReportingPeriodEndDate\r\nFROM UnionDetail \r\nWHERE RecordType = 'PA'\r\n),\r\nTrailer AS(\r\nSELECT \r\n   CAST(SUM(TotalRecordCount) AS INT) AS TotalRecordCount\r\n  ,CAST(SUM(overpunch(TotalNetAmountDue)) AS BIGINT) AS TotalNetAmountDue\r\nFROM UnionDetail \r\nWHERE RecordType = 'PT'\r\n)\r\nSELECT \r\n   ReportingPeriodStartDate\r\n  ,ReportingPeriodEndDate\r\n  ,TotalRecordCount\r\n  ,TotalNetAmountDue\r\nFROM Header\r\n  CROSS JOIN Trailer"
