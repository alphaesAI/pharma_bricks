  "Querries": [
    {
      "HeaderDataFrame": "SELECT \r\n  explode(RecordsSplitIntoArray) AS Header\r\nFROM SourceData\r\nWHERE\r\nRecordType  = 'H'\r\n",
      "DetailDataFrame": "SELECT \r\n  RecordsSplitIntoArray AS Details\r\nFROM SourceData\r\nWHERE\r\nRecordType = 'D'\r\n",
      "ControlDataFrame": "SELECT \r\n   RecordType\r\n  ,CAST(SUM(RestOfRecord) AS INT) AS RecordCount\r\nFROM SourceData\r\nWHERE\r\nRecordType = 'T'\r\nGROUP BY\r\n   RecordType\r\n"
    }
