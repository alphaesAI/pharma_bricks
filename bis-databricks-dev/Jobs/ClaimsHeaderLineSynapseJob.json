{
  "settings": {
    "name": "ClaimsHeaderLineSynapseJob",
    "new_cluster": {
      "spark_version": "7.0.x-scala2.12",
      "node_type_id": "Standard_DS3_v2",
      "spark_env_vars": {
        "PYSPARK_PYTHON": "/databricks/python3/bin/python3"
      },
      "enable_elastic_disk": true,
      "azure_attributes": {
        "availability": "ON_DEMAND_AZURE"
      },
      "num_workers": 8
    },
    "email_notifications": { "on_failure": "CHANGE_FOR_DEPLOYMENT_emailSetting" },
    "timeout_seconds": 0,
    "schedule": {
      "quartz_cron_expression": "CHANGE_FOR_DEPLOYMENT_cronSetting",
      "timezone_id": "US/Pacific",
      "pause_status": "UNPAUSED"
    },
    "notebook_task": {
      "notebook_path": "/Inbound/ClaimsHeaderLineSynapseJob",
      "revision_timestamp": 0
    },
    "max_concurrent_runs": 1
  },
  "creator_user_name": "admin@entcorecloud.com"
}